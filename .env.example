# Copy to .env (never commit .env) and set real values in the Vercel project too.

# Anthropic API key for the forecasting model.
ANTHROPIC_API_KEY=

# Optional: override the model id without a code change (e.g. if the default
# is not available on your account).
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Turso (libSQL) cloud database. Use a token scoped to THIS database only
# (least privilege). Leave unset to use the local data/forecasts.db file.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Bearer token protecting POST /api/forecast. Generate a strong random value
# (>= 24 chars), e.g.:  python -c "import secrets; print(secrets.token_urlsafe(32))"
FORECAST_API_TOKEN=

# Optional: max markets per forecast request (only raise if maxDuration allows).
# FORECAST_MAX_LIMIT=2
